{
  "name": "Controlled BP Readings Submodule",
  "remarks": ["Generates 3 blood pressure readings with controlled values (systolic <140, diastolic <90)"],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "BP_Reading_1"
    },
    "BP_Reading_1": {
      "type": "MultiObservation",
      "category": "vital-signs",
      "codes": [{ "system": "LOINC", "code": "85354-9", "display": "Blood pressure panel" }],
      "observations": [
        {
          "category": "vital-signs",
          "codes": [{ "system": "LOINC", "code": "8480-6", "display": "Systolic blood pressure" }],
          "unit": "mmHg",
          "range": { "low": 110, "high": 138 }
        },
        {
          "category": "vital-signs",
          "codes": [{ "system": "LOINC", "code": "8462-4", "display": "Diastolic blood pressure" }],
          "unit": "mmHg",
          "range": { "low": 60, "high": 88 }
        }
      ],
      "direct_transition": "Wait_1"
    },
    "Wait_1": {
      "type": "Delay",
      "range": { "low": 30, "high": 90, "unit": "days" },
      "direct_transition": "BP_Reading_2"
    },
    "BP_Reading_2": {
      "type": "MultiObservation",
      "category": "vital-signs",
      "codes": [{ "system": "LOINC", "code": "85354-9", "display": "Blood pressure panel" }],
      "observations": [
        {
          "category": "vital-signs",
          "codes": [{ "system": "LOINC", "code": "8480-6", "display": "Systolic blood pressure" }],
          "unit": "mmHg",
          "range": { "low": 115, "high": 135 }
        },
        {
          "category": "vital-signs",
          "codes": [{ "system": "LOINC", "code": "8462-4", "display": "Diastolic blood pressure" }],
          "unit": "mmHg",
          "range": { "low": 65, "high": 85 }
        }
      ],
      "direct_transition": "Wait_2"
    },
    "Wait_2": {
      "type": "Delay",
      "range": { "low": 30, "high": 90, "unit": "days" },
      "direct_transition": "BP_Reading_3"
    },
    "BP_Reading_3": {
      "type": "MultiObservation",
      "category": "vital-signs",
      "codes": [{ "system": "LOINC", "code": "85354-9", "display": "Blood pressure panel" }],
      "observations": [
        {
          "category": "vital-signs",
          "codes": [{ "system": "LOINC", "code": "8480-6", "display": "Systolic blood pressure" }],
          "unit": "mmHg",
          "range": { "low": 118, "high": 132 }
        },
        {
          "category": "vital-signs",
          "codes": [{ "system": "LOINC", "code": "8462-4", "display": "Diastolic blood pressure" }],
          "unit": "mmHg",
          "range": { "low": 70, "high": 82 }
        }
      ],
      "direct_transition": "Terminal"
    },
    "Terminal": { "type": "Terminal" }
  }
}
