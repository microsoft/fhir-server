# Examples demonstrating filtered statistics creation for ReferenceSearchParam (Approach B).
#
# After running a reference search with an explicit target type (e.g., subject=Patient/xyz),
# SQL Server filtered statistics are created on dbo.ReferenceSearchParam with a 3-column
# WHERE clause: ResourceTypeId, SearchParamId, AND ReferenceResourceTypeId.
#
# This gives the query optimizer per-target-type histograms, improving cardinality estimates
# for reference-based searches.
#
# Prerequisites:
#   1. FHIR server running locally (default: localhost:44348)
#   2. Search data loaded via SearchDataBatch.json (see Setup section below)
#
# To verify stats were created, query sys.stats in the FHIR database:
#   SELECT T.name AS TableName, S.name AS StatsName
#   FROM sys.stats S JOIN sys.tables T ON T.object_id = S.object_id
#   WHERE S.name LIKE 'ST[_]ReferenceResourceId%'
#   ORDER BY S.name;

@hostname = localhost:44348

### Get the bearer token, if authentication is enabled
# @name bearer
POST https://{{hostname}}/connect/token
content-type: application/x-www-form-urlencoded

grant_type=client_credentials
&client_id=globalAdminServicePrincipal
&client_secret=globalAdminServicePrincipal
&scope=fhir-api

### Load test data (uses existing SearchDataBatch.json which includes Patient, DiagnosticReport, Observation, Encounter, etc.)
# @name setupData
POST https://{{hostname}}
Content-Type: application/json
Authorization: Bearer {{bearer.response.body.access_token}}

< ./Data/SearchDataBatch.json

#############################################################################
# Reference searches that trigger Approach B stat creation
#############################################################################

### Search DiagnosticReport by subject with explicit Patient target type
# Creates stat: ST_ReferenceResourceId_WHERE_ResourceTypeId_{DiagnosticReport}_SearchParamId_{subject}_ReferenceResourceTypeId_{Patient}
GET https://{{hostname}}/DiagnosticReport?subject=Patient/searchpatient1
Authorization: Bearer {{bearer.response.body.access_token}}

### Search Observation by subject with explicit Patient target type
# Creates stat: ST_ReferenceResourceId_WHERE_ResourceTypeId_{Observation}_SearchParamId_{subject}_ReferenceResourceTypeId_{Patient}
GET https://{{hostname}}/Observation?subject=Patient/searchpatient1
Authorization: Bearer {{bearer.response.body.access_token}}

### Search MedicationRequest by subject with explicit Patient target type
# Creates stat: ST_ReferenceResourceId_WHERE_ResourceTypeId_{MedicationRequest}_SearchParamId_{subject}_ReferenceResourceTypeId_{Patient}
GET https://{{hostname}}/MedicationRequest?subject=Patient/searchpatient1
Authorization: Bearer {{bearer.response.body.access_token}}

### Search Encounter by subject with explicit Patient target type
# Creates stat: ST_ReferenceResourceId_WHERE_ResourceTypeId_{Encounter}_SearchParamId_{subject}_ReferenceResourceTypeId_{Patient}
GET https://{{hostname}}/Encounter?subject=Patient/searchpatient1
Authorization: Bearer {{bearer.response.body.access_token}}

### Search Patient by general-practitioner with explicit Practitioner target type
# Creates stat: ST_ReferenceResourceId_WHERE_ResourceTypeId_{Patient}_SearchParamId_{general-practitioner}_ReferenceResourceTypeId_{Practitioner}
GET https://{{hostname}}/Patient?general-practitioner=Practitioner/searchpractitioner1
Authorization: Bearer {{bearer.response.body.access_token}}

### Search DiagnosticReport by result with explicit Observation target type
# Creates stat: ST_ReferenceResourceId_WHERE_ResourceTypeId_{DiagnosticReport}_SearchParamId_{result}_ReferenceResourceTypeId_{Observation}
GET https://{{hostname}}/DiagnosticReport?result=Observation/searchobservation1
Authorization: Bearer {{bearer.response.body.access_token}}

#############################################################################
# Searches that do NOT trigger Approach B (no explicit target type)
#############################################################################

### Search without type prefix — falls back to old-style 2-column filter stat (null ReferenceResourceTypeId)
GET https://{{hostname}}/DiagnosticReport?subject=searchpatient1
Authorization: Bearer {{bearer.response.body.access_token}}

### Search with :missing modifier — produces NotExists expression, no stats created
GET https://{{hostname}}/DiagnosticReport?subject:missing=true
Authorization: Bearer {{bearer.response.body.access_token}}

#############################################################################
# Non-reference searches (for comparison — these create old-style stats)
#############################################################################

### Token search — creates stat on dbo.TokenSearchParam
GET https://{{hostname}}/Patient?identifier=test%201
Authorization: Bearer {{bearer.response.body.access_token}}

### URI search — creates stat on dbo.UriSearchParam
GET https://{{hostname}}/ValueSet?url=http://example.com/fhir/ValueSet/test
Authorization: Bearer {{bearer.response.body.access_token}}
